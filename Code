<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>InkCover — Kid-Friendly Book Cover Designer</title>
  <style>
    :root{
      --bg1:#f7f2ff;
      --bg2:#ecf9ff;
      --ink:#2b2240;
      --muted:#6c5f8f;
      --card:#ffffffcc;
      --stroke:#e6dcff;
      --accent:#ad73ff;
      --accent2:#5ed9c8;
      --accent3:#ff9f7f;
      --shadow:0 16px 40px rgba(100, 74, 153, .15);
      --radius:24px;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:'Fredoka', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color:var(--ink);
      background:
        radial-gradient(circle at top left, rgba(173,115,255,.18), transparent 28%),
        radial-gradient(circle at top right, rgba(94,217,200,.18), transparent 24%),
        radial-gradient(circle at bottom left, rgba(255,159,127,.16), transparent 22%),
        linear-gradient(180deg, var(--bg1), var(--bg2));
      overflow-x:hidden;
    }
    a{color:inherit}
    button,input,select,textarea{font:inherit}
    .app{min-height:100vh}
    .page{display:none; min-height:100vh}
    .page.active{display:block}
    .wrap{width:min(1180px, calc(100% - 24px)); margin:0 auto}
    .topbar{
      position:sticky; top:0; z-index:20;
      backdrop-filter: blur(14px);
      background:rgba(255,255,255,.55);
      border-bottom:1px solid rgba(160,140,220,.18);
    }
    .topbar-inner{
      display:flex; align-items:center; justify-content:space-between; gap:16px;
      padding:14px 0;
    }
    .brand{display:flex; align-items:center; gap:12px; font-weight:800}
    .logo{
      width:44px; height:44px; border-radius:14px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      box-shadow:0 10px 24px rgba(173,115,255,.3);
      display:grid; place-items:center; color:white; font-size:24px;
    }
    .brand small{display:block; color:var(--muted); font-weight:600}
    .nav{display:flex; gap:10px; flex-wrap:wrap}
    .nav button,.pill, .action-btn{
      border:0; cursor:pointer; border-radius:999px; transition:.2s transform, .2s box-shadow, .2s background, .2s opacity;
      font-weight:700;
    }
    .nav button,.action-btn{
      padding:12px 16px;
      background:white;
      color:var(--accent);
      box-shadow:0 8px 20px rgba(173,115,255,.12);
    }
    .nav button:hover,.action-btn:hover,.hero-btn:hover,.tiny-btn:hover,.chip:hover{transform:translateY(-1px)}
    .nav button.active{background:var(--accent); color:white}
    .hero{
      display:grid; grid-template-columns: 1.05fr .95fr; gap:24px;
      padding:34px 0 42px;
      align-items:center;
    }
    .hero-copy{
      padding:24px 0;
    }
    .kicker{
      display:inline-flex; align-items:center; gap:8px;
      background:rgba(255,255,255,.72); padding:10px 14px; border-radius:999px;
      color:var(--muted); font-weight:700; box-shadow:var(--shadow);
    }
    h1{
      font-size:clamp(42px, 6vw, 74px);
      line-height:.95; margin:18px 0 14px;
      letter-spacing:-.03em;
    }
    .grad{
      background:linear-gradient(90deg, #8e55ff, #4ebed7, #ff8f76);
      -webkit-background-clip:text; background-clip:text; color:transparent;
    }
    .lead{font-size:clamp(16px, 2vw, 20px); color:var(--muted); line-height:1.6; max-width:56ch}
    .hero-actions{display:flex; flex-wrap:wrap; gap:12px; margin-top:24px}
    .hero-btn{
      border:0; border-radius:18px; padding:14px 20px; font-weight:800; cursor:pointer;
      background:var(--accent); color:white; box-shadow:0 14px 28px rgba(173,115,255,.26);
    }
    .hero-btn.secondary{background:white; color:var(--ink)}
    .hero-card{
      background:var(--card); border:1px solid rgba(255,255,255,.8); border-radius:32px; box-shadow:var(--shadow);
      padding:18px;
    }
    .mock{
      aspect-ratio: .78 / 1;
      border-radius:26px;
      background:linear-gradient(180deg, #fff, #fff7ff);
      position:relative; overflow:hidden;
      border:1px solid #eee4ff;
      display:grid;
      place-items:center;
    }
    .mock::before,.mock::after{
      content:""; position:absolute; inset:auto; border-radius:999px; filter:blur(0);
    }
    .mock::before{width:220px;height:220px;background:rgba(173,115,255,.13); top:24px; right:-40px}
    .mock::after{width:180px;height:180px;background:rgba(94,217,200,.12); bottom:20px; left:-30px}
    .book-preview{
      width:72%; aspect-ratio:.72 / 1;
      border-radius:20px; position:relative;
      background:linear-gradient(180deg, #ffd86b, #ff9f7f);
      box-shadow:0 20px 34px rgba(0,0,0,.15);
      overflow:hidden;
    }
    .book-preview .strip{
      position:absolute; inset:0 auto 0 0; width:16px; background:rgba(255,255,255,.35)
    }
    .book-preview .bubble{
      position:absolute; border-radius:999px; background:rgba(255,255,255,.28)
    }
    .bubble.b1{width:64px;height:64px; top:18px; left:16px}
    .bubble.b2{width:34px;height:34px; top:86px; right:20px}
    .bubble.b3{width:82px;height:82px; bottom:22px; left:22px}
    .book-title{
      position:absolute; left:18px; right:18px; top:26px; color:#fff;
      font-size:28px; line-height:.95; font-weight:900; text-shadow:0 4px 12px rgba(0,0,0,.18);
    }
    .book-sub{position:absolute; left:18px; right:18px; top:118px; color:rgba(255,255,255,.95); font-weight:700}
    .book-author{position:absolute; left:18px; right:18px; bottom:20px; color:white; font-size:18px; font-weight:800}
    .section{padding:10px 0 38px}
    .grid3{display:grid; grid-template-columns:repeat(3, 1fr); gap:16px}
    .feature{
      background:rgba(255,255,255,.76); border:1px solid rgba(230,220,255,.9);
      border-radius:24px; padding:18px; box-shadow:var(--shadow)
    }
    .feature h3{margin:10px 0 6px}
    .feature p{margin:0; color:var(--muted); line-height:1.55}
    .feature .emoji{font-size:28px}
    .editor-shell{
      display:grid; grid-template-columns: 360px 1fr; gap:18px; padding:20px 0 34px;
      align-items:start;
    }
    .panel{
      background:rgba(255,255,255,.8); border:1px solid rgba(230,220,255,.95);
      border-radius:26px; box-shadow:var(--shadow);
      overflow:hidden;
    }
    .panel h2,.panel h3{margin:0}
    .panel-head{
      padding:16px 18px; border-bottom:1px solid rgba(230,220,255,.8);
      background:linear-gradient(180deg, rgba(255,255,255,.85), rgba(248,243,255,.7));
    }
    .panel-body{padding:16px 18px}
    .field{margin-bottom:14px}
    .field label{display:flex; justify-content:space-between; gap:12px; font-size:14px; font-weight:800; margin-bottom:7px}
    .field input[type="text"], .field textarea, .field select{
      width:100%; padding:12px 14px; border-radius:16px; border:1px solid #e1d7fa; background:white; color:var(--ink);
      outline:none;
    }
    .field textarea{min-height:76px; resize:vertical}
    .row{display:grid; grid-template-columns:1fr 1fr; gap:10px}
    .swatches{display:grid; grid-template-columns:repeat(6,1fr); gap:8px}
    .swatch{
      width:100%; aspect-ratio:1; border-radius:14px; border:3px solid white; box-shadow:0 6px 14px rgba(0,0,0,.08);
      cursor:pointer;
    }
    .swatch.active{outline:3px solid var(--ink)}
    .chips{display:flex; flex-wrap:wrap; gap:8px}
    .chip{
      border:1px solid #e3daf8; background:white; color:var(--ink); padding:9px 12px; border-radius:999px; cursor:pointer;
    }
    .chip.active{background:var(--accent); color:white; border-color:var(--accent)}
    .tiny-btn{
      border:0; cursor:pointer; border-radius:12px; padding:10px 12px; background:white; color:var(--accent); font-weight:800;
      box-shadow:0 8px 16px rgba(173,115,255,.10);
    }
    .editor-main{
      display:grid; grid-template-columns: 1.1fr .9fr; gap:18px;
    }
    .stage{
      background:rgba(255,255,255,.8); border:1px solid rgba(230,220,255,.95);
      border-radius:26px; box-shadow:var(--shadow);
      padding:16px;
    }
    .cover-wrap{
      display:grid; place-items:center; padding:10px;
    }
    .cover{
      width:min(100%, 420px); aspect-ratio:.72 / 1; border-radius:26px; position:relative; overflow:hidden;
      box-shadow:0 20px 50px rgba(61, 30, 120, .24);
      background:linear-gradient(180deg, #ffd76e, #ff7f91);
      border:10px solid rgba(255,255,255,.55);
      touch-action:none;
    }
    .cover .texture{
      position:absolute; inset:0; background:
        radial-gradient(circle at 20% 18%, rgba(255,255,255,.23) 0 5px, transparent 6px),
        radial-gradient(circle at 76% 26%, rgba(255,255,255,.22) 0 7px, transparent 8px),
        radial-gradient(circle at 34% 72%, rgba(255,255,255,.17) 0 6px, transparent 7px),
        radial-gradient(circle at 80% 76%, rgba(255,255,255,.18) 0 8px, transparent 9px);
      mix-blend-mode:screen; pointer-events:none
    }
    .cover-art{
      position:absolute; inset:0; background-position:center; background-size:cover; opacity:.98;
      transform:translateZ(0);
    }
    .cover-art.cover-fit{background-size:contain; background-repeat:no-repeat}
    .overlay{
      position:absolute; inset:0; display:flex; flex-direction:column; justify-content:space-between;
      padding:20px;
      color:white;
      text-shadow:0 3px 12px rgba(0,0,0,.18);
    }
    .title-box{margin-top:4px}
    .title{
      font-size:clamp(30px, 5vw, 46px); line-height:.92; margin:0; font-weight:900;
      word-break:break-word;
    }
    .subtitle{
      margin:10px 0 0; font-size:clamp(15px, 2vw, 18px); font-weight:700; opacity:.98;
      word-break:break-word;
    }
    .author{
      font-size:clamp(15px, 1.8vw, 20px); font-weight:900; align-self:flex-end;
      margin-top:20px; word-break:break-word;
    }
    .badge{
      align-self:flex-start;
      padding:8px 12px; border-radius:999px;
      background:rgba(255,255,255,.2); backdrop-filter: blur(10px);
      border:1px solid rgba(255,255,255,.28);
      font-size:12px; font-weight:800; letter-spacing:.04em; text-transform:uppercase;
    }
    .art-controls{
      display:flex; gap:10px; flex-wrap:wrap; margin-top:12px
    }
    .library-list{display:grid; gap:10px}
    .lib-item{
      display:grid; grid-template-columns: 64px 1fr auto; gap:12px; align-items:center;
      background:white; border:1px solid #eadffd; border-radius:18px; padding:10px;
    }
    .thumb{
      width:64px; aspect-ratio:.72 / 1; border-radius:12px; overflow:hidden; background:linear-gradient(180deg, #ffd76e, #ff7f91);
      border:1px solid rgba(0,0,0,.05)
    }
    .thumb img{width:100%; height:100%; object-fit:cover; display:block}
    .lib-meta{min-width:0}
    .lib-meta strong{display:block; white-space:nowrap; overflow:hidden; text-overflow:ellipsis}
    .lib-meta span{display:block; color:var(--muted); font-size:13px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis}
    .lib-actions{display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end}
    .footer-note{padding:0 0 24px; color:var(--muted); text-align:center}
    .hidden{display:none !important}
    @media (max-width: 980px){
      .hero, .editor-shell, .editor-main, .grid3{grid-template-columns:1fr}
    }
    @media (max-width: 640px){
      .topbar-inner{flex-direction:column; align-items:flex-start}
      .nav{width:100%}
      .nav button{flex:1}
      .row{grid-template-columns:1fr}
      .swatches{grid-template-columns:repeat(4, 1fr)}
      .lib-item{grid-template-columns: 52px 1fr}
      .lib-actions{grid-column:1 / -1; justify-content:flex-start}
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="wrap topbar-inner">
        <div class="brand" aria-label="InkCover">
          <div class="logo">✎</div>
          <div>
            InkCover
            <small>Kid-friendly book cover designer</small>
          </div>
        </div>
        <nav class="nav" aria-label="Main navigation">
          <button id="navHome" class="active" type="button">Home</button>
          <button id="navEditor" type="button">Editor</button>
          <button id="navLibrary" type="button">Library</button>
        </nav>
      </div>
    </header>

    <main>
      <section id="homePage" class="page active" aria-labelledby="homeTitle">
        <div class="wrap hero">
          <div class="hero-copy">
            <div class="kicker">🌈 Make magical covers in minutes</div>
            <h1 id="homeTitle">Design a <span class="grad">wonderful book cover</span> with InkCover.</h1>
            <p class="lead">Create playful covers with bright colors, kid-friendly templates, custom fonts, and your own artwork. Save every project to your library and download it when you’re ready to share.</p>
            <div class="hero-actions">
              <button class="hero-btn" id="startCreating" type="button">Start Designing</button>
              <button class="hero-btn secondary" id="browseLibrary" type="button">Open Library</button>
            </div>
          </div>
          <div class="hero-card" aria-label="Example book cover">
            <div class="mock">
              <div class="book-preview" id="homePreview">
                <div class="strip"></div>
                <div class="bubble b1"></div><div class="bubble b2"></div><div class="bubble b3"></div>
                <div class="book-title" id="homePreviewTitle">The Moon<br>Ice Cream<br>Adventure</div>
                <div class="book-sub" id="homePreviewSub">A sparkling story for brave dreamers</div>
                <div class="book-author" id="homePreviewAuthor">by Luna Bloom</div>
              </div>
            </div>
          </div>
        </div>

        <div class="wrap section">
          <div class="grid3">
            <div class="feature">
              <div class="emoji">🎨</div>
              <h3>Colorful templates</h3>
              <p>Pick from fun cover styles and instantly change the mood, layout, and visual vibe.</p>
            </div>
            <div class="feature">
              <div class="emoji">🖼️</div>
              <h3>Upload cover art</h3>
              <p>Add your own image and position it with a clean, simple browser-native editor experience.</p>
            </div>
            <div class="feature">
              <div class="emoji">💾</div>
              <h3>Save your projects</h3>
              <p>Store projects in your browser library with localStorage and come back anytime.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="editorPage" class="page" aria-labelledby="editorTitle">
        <div class="wrap section">
          <div class="editor-shell">
            <aside class="panel">
              <div class="panel-head">
                <h2 id="editorTitle">Editor</h2>
              </div>
              <div class="panel-body">
                <div class="field">
                  <label for="projectName">Project name</label>
                  <input id="projectName" type="text" placeholder="My amazing book">
                </div>
                <div class="field">
                  <label for="titleInput">Book title</label>
                  <input id="titleInput" type="text" placeholder="The Great Stargazer">
                </div>
                <div class="field">
                  <label for="subtitleInput">Subtitle</label>
                  <input id="subtitleInput" type="text" placeholder="A cosmic tale of courage">
                </div>
                <div class="field">
                  <label for="authorInput">Author name</label>
                  <input id="authorInput" type="text" placeholder="by Jamie Star">
                </div>
                <div class="field">
                  <label for="fontSelect">Font picker</label>
                  <select id="fontSelect"></select>
                </div>
                <div class="field">
                  <label>Template</label>
                  <div class="chips" id="templateChips"></div>
                </div>
                <div class="field">
                  <label>Colors</label>
                  <div class="row">
                    <input id="primaryColor" type="color" value="#ff8f76" aria-label="Primary color">
                    <input id="secondaryColor" type="color" value="#ffd76e" aria-label="Secondary color">
                  </div>
                  <div class="swatches" id="swatches"></div>
                </div>
                <div class="field">
                  <label for="artUpload">Upload cover art</label>
                  <input id="artUpload" type="file" accept="image/*">
                  <div class="art-controls">
                    <button class="tiny-btn" id="fitArtBtn" type="button">Fit</button>
                    <button class="tiny-btn" id="coverArtBtn" type="button">Cover</button>
                    <button class="tiny-btn" id="removeArtBtn" type="button">Remove art</button>
                  </div>
                </div>
                <div class="field">
                  <label for="customizeText">Customise the book</label>
                  <textarea id="customizeText" placeholder="Add a short blurb, theme notes, or fun details..."></textarea>
                </div>
                <div class="row">
                  <button class="action-btn" id="saveBtn" type="button">Save to Library</button>
                  <button class="action-btn" id="downloadBtn" type="button">Download PNG</button>
                </div>
                <div class="row" style="margin-top:10px">
                  <button class="action-btn" id="exportSvgBtn" type="button">Download SVG</button>
                  <button class="action-btn" id="resetBtn" type="button">Reset</button>
                </div>
              </div>
            </aside>

            <section class="stage">
              <div class="cover-wrap">
                <div class="cover" id="coverStage" aria-label="Live book cover preview">
                  <div class="cover-art" id="coverArt"></div>
                  <div class="texture"></div>
                  <div class="overlay" id="coverOverlay">
                    <div>
                      <div class="badge" id="templateBadge">Template</div>
                      <div class="title-box">
                        <h3 class="title" id="previewTitle">The Great Stargazer</h3>
                        <p class="subtitle" id="previewSubtitle">A cosmic tale of courage</p>
                      </div>
                    </div>
                    <div class="author" id="previewAuthor">by Jamie Star</div>
                  </div>
                </div>
              </div>
            </section>

            <aside class="panel">
              <div class="panel-head">
                <h2>Library</h2>
              </div>
              <div class="panel-body">
                <p style="margin-top:0;color:var(--muted);line-height:1.5">Your saved covers stay in this browser.</p>
                <div class="library-list" id="libraryList"></div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <div class="footer-note wrap">Built for creative kids, curious grownups, and speedy cover-making fun.</div>
  </div>

  <script>
    (function(){
      const $ = (s, r=document) => r.querySelector(s);
      const $$ = (s, r=document) => Array.from(r.querySelectorAll(s));
      const pages = { home: $('#homePage'), editor: $('#editorPage') };
      const navHome = $('#navHome'), navEditor = $('#navEditor'), navLibrary = $('#navLibrary');
      const startCreating = $('#startCreating'), browseLibrary = $('#browseLibrary');

      const fonts = [
        'Fredoka','Helvetica','Times New Roman','Garamond','Arial','Futura','Bodoni','Rockwell','Franklin Gothic','Baskerville',
        'Calibri','Georgia','Verdana','Gill Sans','Univers','Optima','ITC Avant Garde Gothic','Palatino','Courier New','Impact',
        'Century Gothic','Geneva','Lucida Console','Comic Sans MS','Trajan','Bookman','Cochin','Myriad','Minion',
        'Source Serif Pro','Adobe Caslon','FF Meta','Freight Text','Sabon','Plantin','Perpetua','Roboto','Open Sans','Lato',
        'Montserrat','Raleway','Inter','Poppins','Work Sans','DM Sans','Ubuntu','Merriweather','Playfair Display','Source Sans Pro',
        'Noto Sans','Oswald','Nunito','Fira Sans','Archivo Narrow','Rubik','Lora','Exo 2','Libre Baskerville','Droid Sans','Chivo',
        'Bitter','Josefin Sans','Manrope','Zilla Slab','Kanit','Space Mono'
      ];

      const templates = [
        {id:'sparkle', name:'Sparkle', bg:'linear-gradient(180deg, #ff7eb3, #ffb36b)'},
        {id:'space', name:'Space', bg:'linear-gradient(180deg, #5a67ff, #7a3cff)'},
        {id:'jungle', name:'Jungle', bg:'linear-gradient(180deg, #55d28b, #1aa7a1)'},
        {id:'rainbow', name:'Rainbow', bg:'linear-gradient(180deg, #ff7c7c, #ffdf5c)'},
        {id:'ocean', name:'Ocean', bg:'linear-gradient(180deg, #4cb8ff, #5ed9c8)'}
      ];

      const presetColors = ['#ff8f76','#ffd76e','#ad73ff','#5ed9c8','#4cb8ff','#ff7eb3','#55d28b','#7a3cff','#2b2240','#ffffff','#f5e9ff','#ffe9d9'];

      const state = {
        projectName:'Untitled',
        title:'The Great Stargazer',
        subtitle:'A cosmic tale of courage',
        author:'by Jamie Star',
        font:'Fredoka',
        template:'sparkle',
        primaryColor:'#ff8f76',
        secondaryColor:'#ffd76e',
        customText:'',
        artData:'',
        artMode:'cover'
      };

      function showPage(name){
        Object.entries(pages).forEach(([k, el]) => el.classList.toggle('active', k === name));
        navHome.classList.toggle('active', name === 'home');
        navEditor.classList.toggle('active', name === 'editor');
        navLibrary.classList.toggle('active', name === 'editor');
      }

      function loadGoogleFontOnce(){
        if (document.getElementById('fredoka-font')) return;
        const link = document.createElement('link');
        link.id = 'fredoka-font';
        link.rel = 'stylesheet';
        link.href = 'https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700;800&display=swap';
        document.head.appendChild(link);
      }

      function populateFonts(){
        const select = $('#fontSelect');
        fonts.forEach(f => {
          const opt = document.createElement('option');
          opt.value = f;
          opt.textContent = f;
          opt.style.fontFamily = `"${f}", ${genericFamily(f)}`;
          select.appendChild(opt);
        });
      }

      function genericFamily(font){
        const serif = ['Times New Roman','Garamond','Bodoni','Baskerville','Georgia','Palatino','Trajan','Bookman','Cochin','Minion','Source Serif Pro','Adobe Caslon','Freight Text','Sabon','Plantin','Perpetua','Merriweather','Playfair Display','Lora','Libre Baskerville','Bitter','Zilla Slab'];
        const mono = ['Courier New','Lucida Console','Space Mono'];
        const sans = ['Helvetica','Arial','Futura','Rockwell','Franklin Gothic','Calibri','Verdana','Gill Sans','Univers','Optima','ITC Avant Garde Gothic','Century Gothic','Geneva','Comic Sans MS','Myriad','Roboto','Open Sans','Lato','Montserrat','Raleway','Inter','Poppins','Work Sans','DM Sans','Ubuntu','Source Sans Pro','Noto Sans','Oswald','Nunito','Fira Sans','Archivo Narrow','Rubik','Josefin Sans','Manrope','Kanit','Droid Sans','Chivo','Exo 2','Archivo Narrow'];
        if (mono.includes(font)) return 'monospace';
        if (serif.includes(font)) return 'serif';
        if (sans.includes(font)) return 'sans-serif';
        return 'sans-serif';
      }

      function populateTemplates(){
        const wrap = $('#templateChips');
        templates.forEach(t => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'chip';
          btn.textContent = t.name;
          btn.dataset.template = t.id;
          btn.addEventListener('click', () => {
            state.template = t.id;
            render();
          });
          wrap.appendChild(btn);
        });
      }

      function populateSwatches(){
        const wrap = $('#swatches');
        presetColors.forEach(c => {
          const b = document.createElement('button');
          b.type='button';
          b.className='swatch';
          b.style.background = c;
          b.title = c;
          b.setAttribute('aria-label', c);
          b.addEventListener('click', () => { state.primaryColor = c; $('#primaryColor').value = c; render(); });
          wrap.appendChild(b);
        });
      }

      function templateStyle(id){
        const map = {
          sparkle:{bg:`linear-gradient(180deg, ${state.primaryColor}, ${state.secondaryColor})`, overlay:'rgba(255,255,255,.12)'},
          space:{bg:`linear-gradient(180deg, ${state.secondaryColor}, ${state.primaryColor})`, overlay:'rgba(12,16,50,.15)'},
          jungle:{bg:'linear-gradient(180deg, #55d28b, #1aa7a1)', overlay:'rgba(255,255,255,.12)'},
          rainbow:{bg:'linear-gradient(180deg, #ff7c7c, #ffdf5c)', overlay:'rgba(255,255,255,.12)'},
          ocean:{bg:'linear-gradient(180deg, #4cb8ff, #5ed9c8)', overlay:'rgba(255,255,255,.12)'}
        };
        return map[id] || map.sparkle;
      }

      function render(){
        const title = state.title.trim() || 'Untitled';
        const subtitle = state.subtitle.trim();
        const author = state.author.trim();
        const fontStack = `"${state.font}", ${genericFamily(state.font)}, system-ui, sans-serif`;

        $('#previewTitle').textContent = title;
        $('#previewSubtitle').textContent = subtitle || ' ';
        $('#previewAuthor').textContent = author || ' ';
        $('#previewTitle').style.fontFamily = fontStack;
        $('#previewSubtitle').style.fontFamily = fontStack;
        $('#previewAuthor').style.fontFamily = fontStack;
        $('#coverStage').style.background = templateStyle(state.template).bg;
        $('#homePreview').style.background = templateStyle(state.template).bg;
        $('#coverArt').style.backgroundImage = state.artData ? `url("${state.artData}")` : 'none';
        $('#coverArt').classList.toggle('cover-fit', state.artMode === 'fit');

        if (state.artData){
          $('#coverArt').style.opacity = '1';
        } else {
          $('#coverArt').style.opacity = '0';
        }

        $('#templateBadge').textContent = templates.find(t => t.id === state.template)?.name || 'Template';
        $('#templateBadge').style.fontFamily = fontStack;
        $('#templateBadge').style.background = templateStyle(state.template).overlay;

        $('#coverOverlay').style.color = '#fff';
        $('#homePreviewTitle').style.fontFamily = fontStack;
        $('#homePreviewSub').style.fontFamily = fontStack;
        $('#homePreviewAuthor').style.fontFamily = fontStack;
        $('#homePreview').style.fontFamily = fontStack;
        $('#homePreviewTitle').style.color = '#fff';
        $('#homePreviewSub').textContent = subtitle || 'A sparkling story for brave dreamers';
        $('#homePreviewAuthor').textContent = author || 'by Luna Bloom';

        $('#projectName').value = state.projectName;
        $('#titleInput').value = state.title;
        $('#subtitleInput').value = state.subtitle;
        $('#authorInput').value = state.author;
        $('#fontSelect').value = state.font;
        $('#primaryColor').value = state.primaryColor;
        $('#secondaryColor').value = state.secondaryColor;
        $('#customizeText').value = state.customText || '';

        $$('.chip', $('#templateChips')).forEach(b => b.classList.toggle('active', b.dataset.template === state.template));
        $$('.swatch', $('#swatches')).forEach(b => b.classList.toggle('active', b.style.background.replace(/\s/g,'') === state.primaryColor.replace(/\s/g,'')));

        $('#coverStage').style.setProperty('--accent', state.primaryColor);

        $('#coverStage').style.fontFamily = fontStack;
      }

      function syncFromInputs(){
        state.projectName = $('#projectName').value;
        state.title = $('#titleInput').value;
        state.subtitle = $('#subtitleInput').value;
        state.author = $('#authorInput').value;
        state.font = $('#fontSelect').value;
        state.primaryColor = $('#primaryColor').value;
        state.secondaryColor = $('#secondaryColor').value;
        state.customText = $('#customizeText').value;
        render();
      }

      function saveLibrary(projectOverride){
        const project = projectOverride || serializeProject();
        const library = getLibrary();
        const existingIndex = library.findIndex(x => x.id === project.id);
        if (existingIndex >= 0) library[existingIndex] = project; else library.unshift(project);
        localStorage.setItem('inkcover-library', JSON.stringify(library.slice(0, 24)));
        refreshLibrary();
      }

      function serializeProject(){
        return {
          id: Date.now().toString(36) + Math.random().toString(36).slice(2,7),
          projectName: state.projectName || 'Untitled',
          title: state.title || 'Untitled',
          subtitle: state.subtitle || '',
          author: state.author || '',
          font: state.font,
          template: state.template,
          primaryColor: state.primaryColor,
          secondaryColor: state.secondaryColor,
          customText: state.customText || '',
          artData: state.artData || '',
          artMode: state.artMode || 'cover',
          savedAt: new Date().toISOString()
        };
      }

      function getLibrary(){
        try { return JSON.parse(localStorage.getItem('inkcover-library') || '[]'); }
        catch(e){ return []; }
      }

      function refreshLibrary(){
        const list = $('#libraryList');
        const library = getLibrary();
        list.innerHTML = '';
        if (!library.length){
          const empty = document.createElement('div');
          empty.className = 'feature';
          empty.innerHTML = '<div class="emoji">📚</div><h3>No saved covers yet</h3><p>Save a project to see it appear here.</p>';
          list.appendChild(empty);
          return;
        }
        library.forEach(item => {
          const row = document.createElement('div');
          row.className = 'lib-item';
          const thumb = document.createElement('div');
          thumb.className = 'thumb';
          if (item.artData){
            const img = document.createElement('img');
            img.src = item.artData;
            thumb.appendChild(img);
          } else {
            thumb.style.background = templateStyle(item.template).bg;
          }
          const meta = document.createElement('div');
          meta.className = 'lib-meta';
          meta.innerHTML = `<strong>${escapeHtml(item.projectName || item.title || 'Untitled')}</strong><span>${escapeHtml(item.title || '')} · ${escapeHtml(item.template || '')}</span>`;
          const actions = document.createElement('div');
          actions.className = 'lib-actions';
          const openBtn = document.createElement('button');
          openBtn.className = 'tiny-btn';
          openBtn.type = 'button';
          openBtn.textContent = 'Open';
          openBtn.addEventListener('click', () => { loadProject(item); showPage('editor'); });
          const delBtn = document.createElement('button');
          delBtn.className = 'tiny-btn';
          delBtn.type = 'button';
          delBtn.textContent = 'Delete';
          delBtn.addEventListener('click', () => {
            localStorage.setItem('inkcover-library', JSON.stringify(getLibrary().filter(x => x.id !== item.id)));
            refreshLibrary();
          });
          actions.append(openBtn, delBtn);
          row.append(thumb, meta, actions);
          list.appendChild(row);
        });
      }

      function loadProject(item){
        state.projectName = item.projectName || 'Untitled';
        state.title = item.title || '';
        state.subtitle = item.subtitle || '';
        state.author = item.author || '';
        state.font = item.font || 'Fredoka';
        state.template = item.template || 'sparkle';
        state.primaryColor = item.primaryColor || '#ff8f76';
        state.secondaryColor = item.secondaryColor || '#ffd76e';
        state.customText = item.customText || '';
        state.artData = item.artData || '';
        state.artMode = item.artMode || 'cover';
        render();
      }

      function escapeHtml(str){
        return String(str || '').replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;'}[s]));
      }

      async function exportPNG(){
        const cover = $('#coverStage');
        const rect = cover.getBoundingClientRect();
        const scale = 2;
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(rect.width * scale);
        canvas.height = Math.round(rect.height * scale);
        const ctx = canvas.getContext('2d');

        const bg = templateStyle(state.template).bg;
        const bgCanvas = document.createElement('canvas');
        bgCanvas.width = canvas.width;
        bgCanvas.height = canvas.height;
        const bgCtx = bgCanvas.getContext('2d');
        const grad = bgCtx.createLinearGradient(0, 0, 0, canvas.height);
        if (state.template === 'space') { grad.addColorStop(0, state.secondaryColor); grad.addColorStop(1, state.primaryColor); }
        else if (state.template === 'jungle') { grad.addColorStop(0, '#55d28b'); grad.addColorStop(1, '#1aa7a1'); }
        else if (state.template === 'rainbow') { grad.addColorStop(0, '#ff7c7c'); grad.addColorStop(1, '#ffdf5c'); }
        else if (state.template === 'ocean') { grad.addColorStop(0, '#4cb8ff'); grad.addColorStop(1, '#5ed9c8'); }
        else { grad.addColorStop(0, state.primaryColor); grad.addColorStop(1, state.secondaryColor); }
        bgCtx.fillStyle = grad;
        bgCtx.fillRect(0,0,canvas.width,canvas.height);
        ctx.drawImage(bgCanvas,0,0);

        if (state.artData){
          const img = await loadImage(state.artData);
          if (state.artMode === 'fit'){
            const ratio = Math.min(canvas.width / img.width, canvas.height / img.height);
            const w = img.width * ratio, h = img.height * ratio;
            const x = (canvas.width - w)/2, y = (canvas.height - h)/2;
            ctx.drawImage(img, x, y, w, h);
          } else {
            const ratio = Math.max(canvas.width / img.width, canvas.height / img.height);
            const w = img.width * ratio, h = img.height * ratio;
            const x = (canvas.width - w)/2, y = (canvas.height - h)/2;
            ctx.drawImage(img, x, y, w, h);
          }
        }

        ctx.fillStyle = 'rgba(255,255,255,.18)';
        ctx.fillRect(0,0,canvas.width,canvas.height);

        ctx.fillStyle = 'rgba(255,255,255,.2)';
        ctx.fillRect(0,0,Math.round(18*scale), canvas.height);

        const fontStack = `"${state.font}", ${genericFamily(state.font)}, sans-serif`;
        const title = state.title || 'Untitled';
        const subtitle = state.subtitle || '';
        const author = state.author || '';
        const pad = 22 * scale;
        ctx.textBaseline = 'top';
        ctx.fillStyle = 'white';
        ctx.shadowColor = 'rgba(0,0,0,.22)';
        ctx.shadowBlur = 18 * scale;
        ctx.shadowOffsetY = 4 * scale;

        drawWrappedText(ctx, title, pad, pad, canvas.width - pad*2, 46*scale, `900 ${38*scale}px ${fontStack}`);
        ctx.font = `700 ${18*scale}px ${fontStack}`;
        ctx.fillText(subtitle, pad, 150*scale);

        ctx.textAlign = 'right';
        ctx.font = `900 ${20*scale}px ${fontStack}`;
        ctx.fillText(author, canvas.width - pad, canvas.height - 44*scale);
        ctx.textAlign = 'left';

        const a = document.createElement('a');
        a.download = (state.projectName || state.title || 'inkcover') + '.png';
        a.href = canvas.toDataURL('image/png');
        a.click();
      }

      async function exportSVG(){
        const title = escapeXml(state.title || 'Untitled');
        const subtitle = escapeXml(state.subtitle || '');
        const author = escapeXml(state.author || '');
        const bg = svgGradient(state);
        const art = state.artData ? `<image href="${state.artData}" x="0" y="0" width="100%" height="100%" preserveAspectRatio="${state.artMode === 'fit' ? 'xMidYMid meet' : 'xMidYMid slice'}" />` : '';
        const svg = `<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="1667" viewBox="0 0 1200 1667">
  <defs>
    ${bg}
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="20" stdDeviation="28" flood-color="rgba(0,0,0,.25)"/>
    </filter>
  </defs>
  <rect width="1200" height="1667" fill="url(#g)"/>
  ${art}
  <rect width="1200" height="1667" fill="rgba(255,255,255,.14)"/>
  <rect x="0" y="0" width="56" height="1667" fill="rgba(255,255,255,.26)"/>
  <g filter="url(#shadow)" fill="#fff">
    <text x="80" y="170" font-size="84" font-weight="900" font-family="${escapeXml(state.font)}, sans-serif">${title}</text>
    <text x="80" y="280" font-size="38" font-weight="700" font-family="${escapeXml(state.font)}, sans-serif">${subtitle}</text>
    <text x="1120" y="1580" font-size="46" font-weight="900" text-anchor="end" font-family="${escapeXml(state.font)}, sans-serif">${author}</text>
  </g>
</svg>`;
        downloadText((state.projectName || state.title || 'inkcover') + '.svg', svg, 'image/svg+xml');
      }

      function svgGradient(state){
        const c1 = state.primaryColor || '#ff8f76';
        const c2 = state.secondaryColor || '#ffd76e';
        return `<linearGradient id="g" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${c1}"/><stop offset="100%" stop-color="${c2}"/></linearGradient>`;
      }

      function escapeXml(s){ return String(s || '').replace(/[<>&'"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','\'':'&apos;','"':'&quot;'}[c])); }

      function downloadText(filename, text, mime){
        const blob = new Blob([text], {type: mime || 'text/plain;charset=utf-8'});
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = filename;
        a.click();
        setTimeout(() => URL.revokeObjectURL(a.href), 1000);
      }

      function loadImage(src){
        return new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => resolve(img);
          img.onerror = reject;
          img.src = src;
        });
      }

      function drawWrappedText(ctx, text, x, y, maxWidth, lineHeight, font){
        ctx.font = font;
        const words = String(text || '').split(/\s+/);
        let line = '', lines = [];
        words.forEach(word => {
          const test = line ? line + ' ' + word : word;
          if (ctx.measureText(test).width > maxWidth && line) {
            lines.push(line); line = word;
          } else line = test;
        });
        if (line) lines.push(line);
        lines.slice(0, 4).forEach((l, i) => ctx.fillText(l, x, y + i * lineHeight));
      }

      function setListeners(){
        ['projectName','titleInput','subtitleInput','authorInput','fontSelect','primaryColor','secondaryColor','customizeText'].forEach(id => {
          $('#'+id).addEventListener('input', syncFromInputs);
          $('#'+id).addEventListener('change', syncFromInputs);
        });
        $('#artUpload').addEventListener('change', async e => {
          const file = e.target.files && e.target.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = () => { state.artData = reader.result; render(); };
          reader.readAsDataURL(file);
        });
        $('#fitArtBtn').addEventListener('click', () => { state.artMode = 'fit'; render(); });
        $('#coverArtBtn').addEventListener('click', () => { state.artMode = 'cover'; render(); });
        $('#removeArtBtn').addEventListener('click', () => { state.artData = ''; $('#artUpload').value=''; render(); });
        $('#saveBtn').addEventListener('click', () => {
          state.projectName = $('#projectName').value || state.title || 'Untitled';
          saveLibrary(serializeProject());
        });
        $('#downloadBtn').addEventListener('click', exportPNG);
        $('#exportSvgBtn').addEventListener('click', exportSVG);
        $('#resetBtn').addEventListener('click', () => {
          Object.assign(state, {
            projectName:'Untitled', title:'The Great Stargazer', subtitle:'A cosmic tale of courage', author:'by Jamie Star',
            font:'Fredoka', template:'sparkle', primaryColor:'#ff8f76', secondaryColor:'#ffd76e', customText:'', artData:'', artMode:'cover'
          });
          $('#artUpload').value='';
          render();
        });

        navHome.addEventListener('click', () => showPage('home'));
        navEditor.addEventListener('click', () => showPage('editor'));
        navLibrary.addEventListener('click', () => { showPage('editor'); refreshLibrary(); document.getElementById('libraryList').scrollIntoView({behavior:'smooth', block:'start'}); });
        startCreating.addEventListener('click', () => showPage('editor'));
        browseLibrary.addEventListener('click', () => { showPage('editor'); refreshLibrary(); });
      }

      loadGoogleFontOnce();
      populateFonts();
      populateTemplates();
      populateSwatches();
      setListeners();
      render();
      refreshLibrary();
      showPage('home');
    })();
  </script>
</body>
